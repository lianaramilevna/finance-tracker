PORT=5000
CLIENT_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=your_password

JWT_SECRET=change_me_to_long_random_string
JWT_EXPIRES_IN=7d

# ИИ-помощник (Hugging Face Router)
LLM_ENABLED=true
HF_API_TOKEN=hf_your_token_here
HF_MODEL=meta-llama/Llama-3.2-1B-Instruct
# Если конкретная модель иногда недоступна, можно задать фолбэк-список:
# HF_FALLBACK_MODELS=meta-llama/Llama-3.1-8B-Instruct,Qwen/Qwen2.5-7B-Instruct,meta-llama/Llama-3.2-1B-Instruct
# HF_ROUTER_URL=https://router.huggingface.co/v1
